rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function publicDemoCompany(companyId) {
      return companyId == 'demo-company';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() ? userDoc().data.role : null;
    }

    function userCompany() {
      return signedIn() ? userDoc().data.companyId : null;
    }

    function isAdmin() {
      return userRole() == 'admin' && request.auth.token.email == 'admin@sistemadefrota.com';
    }

    function isManager() {
      return isAdmin() || userRole() == 'gestor';
    }

    function isGarageLeader() {
      return isAdmin() || userRole() in ['gestor', 'lider_garagem'];
    }

    function sameCompany(companyId) {
      return signedIn() && (isAdmin() || userCompany() == companyId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isManager());
      allow create, update, delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if sameCompany(companyId);
      allow create: if isAdmin() && userCompany() == companyId;
      allow update, delete: if isAdmin();
    }

    match /licenseKeys/{keyId} {
      allow read: if isManager();
      allow create, update, delete: if false;

      match /activations/{activationId} {
        allow read: if isManager();
        allow write: if false;
      }
    }

    match /vehicles/{vehicleId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if isManager() && (sameCompany(request.resource.data.companyId) || publicDemoCompany(request.resource.data.companyId));
      allow update: if (
        isManager() && sameCompany(resource.data.companyId) && sameCompany(request.resource.data.companyId)
      ) || (
        signedIn() &&
        userRole() == 'lider_garagem' &&
        sameCompany(resource.data.companyId) &&
        sameCompany(request.resource.data.companyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'releasedToDriverId',
          'releasedToDriverNumber',
          'releasedToDriverName',
          'releasedAt',
          'releasedBy',
          'releaseNotes',
          'releasedFromStatus',
          'companyId',
          'updatedAt'
        ])
      ) || (
        isManager() &&
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId)
      ) || (
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'currentKm',
          'releasedToDriverId',
          'releasedToDriverNumber',
          'releasedToDriverName',
          'releasedAt',
          'releasedBy',
          'releaseNotes',
          'releasedFromStatus',
          'updatedAt'
        ])
      ) || (
        signedIn() &&
        userRole() == 'motorista' &&
        sameCompany(resource.data.companyId) &&
        sameCompany(request.resource.data.companyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'currentKm',
          'releasedToDriverId',
          'releasedToDriverNumber',
          'releasedToDriverName',
          'releasedAt',
          'releasedBy',
          'releaseNotes',
          'releasedFromStatus',
          'updatedAt'
        ])
      );
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /drivers/{driverId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if isManager() && (sameCompany(request.resource.data.companyId) || publicDemoCompany(request.resource.data.companyId));
      allow update: if (
        isManager() && sameCompany(resource.data.companyId) && sameCompany(request.resource.data.companyId)
      ) || (
        isManager() &&
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId)
      ) || (
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      ) || (
        signedIn() &&
        userRole() == 'motorista' &&
        resource.data.userId == request.auth.uid &&
        sameCompany(resource.data.companyId) &&
        sameCompany(request.resource.data.companyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /issues/{issueId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if (
        signedIn() && sameCompany(request.resource.data.companyId) && userRole() in ['admin', 'gestor', 'lider_garagem', 'motorista']
      ) || publicDemoCompany(request.resource.data.companyId);
      allow update: if (
        signedIn() &&
        sameCompany(resource.data.companyId) &&
        sameCompany(request.resource.data.companyId) &&
        userRole() in ['admin', 'gestor', 'lider_garagem', 'motorista']
      ) || (
        isManager() &&
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId)
      );
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /maintenance/{maintenanceId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if isManager() && (sameCompany(request.resource.data.companyId) || publicDemoCompany(request.resource.data.companyId));
      allow update: if isManager() && (
        (sameCompany(resource.data.companyId) && sameCompany(request.resource.data.companyId)) ||
        (publicDemoCompany(resource.data.companyId) && publicDemoCompany(request.resource.data.companyId))
      );
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /trips/{tripId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if (
        signedIn() && sameCompany(request.resource.data.companyId) && userRole() in ['admin', 'gestor', 'lider_garagem', 'motorista']
      ) || publicDemoCompany(request.resource.data.companyId);
      allow update: if (
        signedIn() && sameCompany(resource.data.companyId) && sameCompany(request.resource.data.companyId) && userRole() in ['admin', 'gestor', 'lider_garagem', 'motorista']
      ) || (publicDemoCompany(resource.data.companyId) && publicDemoCompany(request.resource.data.companyId));
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /routes/{routeId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if (
        signedIn() && sameCompany(request.resource.data.companyId) && userRole() in ['admin', 'gestor', 'motorista']
      ) || publicDemoCompany(request.resource.data.companyId);
      allow update: if (
        signedIn() && sameCompany(resource.data.companyId) && sameCompany(request.resource.data.companyId) && userRole() in ['admin', 'gestor', 'motorista']
      ) || (publicDemoCompany(resource.data.companyId) && publicDemoCompany(request.resource.data.companyId));
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /vehicleDevices/{deviceId} {
      allow read: if sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId);
      allow create: if (
        isGarageLeader() &&
        (sameCompany(request.resource.data.companyId) || publicDemoCompany(request.resource.data.companyId)) &&
        request.resource.data.deviceId == deviceId
      );
      allow update: if (
        isGarageLeader() &&
        sameCompany(resource.data.companyId) &&
        sameCompany(request.resource.data.companyId)
      ) || (
        isGarageLeader() &&
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId)
      ) || (
        publicDemoCompany(resource.data.companyId) &&
        publicDemoCompany(request.resource.data.companyId) &&
        request.resource.data.deviceId == resource.data.deviceId &&
        request.resource.data.vehicleId == resource.data.vehicleId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deviceId',
          'deviceName',
          'vehicleId',
          'vehicleLabel',
          'companyId',
          'status',
          'lastSeenAt',
          'userAgent',
          'deviceInfo',
          'lastLocation',
          'lastLocationError',
          'updatedAt'
        ])
      );
      allow delete: if isManager() && (sameCompany(resource.data.companyId) || publicDemoCompany(resource.data.companyId));
    }

    match /accessLogs/{logId} {
      allow read: if isAdmin() || (isManager() && sameCompany(resource.data.companyId));
      allow write: if false;
    }

    match /userSessions/{sessionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (
        isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'forceLogout', 'endedAt', 'updatedAt'])
      ) || (
        signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'userId',
          'userName',
          'userEmail',
          'role',
          'companyId',
          'deviceId',
          'browser',
          'os',
          'userAgent',
          'status',
          'createdAt',
          'lastSeenAt',
          'endedAt',
          'updatedAt'
        ])
      );
      allow delete: if false;
    }

    match /syncQueue/{syncId} {
      allow read, create: if signedIn() && request.auth.uid == request.resource.data.userId && sameCompany(request.resource.data.companyId);
      allow update: if signedIn() && request.auth.uid == resource.data.userId && sameCompany(resource.data.companyId);
      allow delete: if isManager() && sameCompany(resource.data.companyId);
    }

    match /mobileGateAnswers/{answerId} {
      allow create: if request.resource.data.keys().hasOnly(['question', 'answerCm', 'createdAt', 'userAgent', 'deviceInfo']) &&
        request.resource.data.question is string &&
        request.resource.data.answerCm is number &&
        request.resource.data.answerCm >= 10 &&
        request.resource.data.answerCm <= 20 &&
        request.resource.data.userAgent is string;
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /managerAccessRequests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'accessKey', 'answer', 'status', 'createdAt', 'userAgent', 'deviceInfo']) &&
        request.resource.data.email is string &&
        request.resource.data.accessKey is string &&
        request.resource.data.accessKey.matches('^[A-Za-z0-9_.@-]{1,128}$') &&
        request.resource.data.answer is string &&
        request.resource.data.answer.matches('^[A-Za-z0-9_.@-]{1,128}$') &&
        request.resource.data.status == 'pending' &&
        request.resource.data.userAgent is string;
      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt']) &&
        request.resource.data.status in ['pending', 'approved', 'rejected'];
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
